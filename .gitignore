# ============================================================
# Keep project files that are needed to open/build the project
# ============================================================

!.gitignore
!.gitattributes
!*.sln
!*.vcxproj
!*.vcxproj.filters
!*.vcxproj.props
!*.props
!*.targets
!*.pro
!*.pri
!*.ui
!*.qrc
!ui_*.h
!package.json
!package-lock.json
!yarn.lock
!pnpm-lock.yaml

